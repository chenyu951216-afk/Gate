APP_NAME=bitget-quant-ranking-scanner
APP_ENV=production
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8080
TIMEZONE=Asia/Taipei
DATABASE_URL=
DATABASE_STARTUP_RETRIES=12
DATABASE_STARTUP_RETRY_DELAY_SECONDS=5

# Gate official REST v4: scanner, ranking, replay and historical market data.
# Gate is not the order venue in this deployment.
GATE_REST_BASE_URL=https://api.gateio.ws/api/v4
GATE_WS_URL=wss://fx-ws.gateio.ws/v4/ws/usdt
GATE_API_KEY=
GATE_API_SECRET=
GATE_SETTLE=usdt
GATE_REQUEST_TIMEOUT_SECONDS=15
GATE_MAX_CONCURRENCY=8
GATE_REQUESTS_PER_SECOND=8
GATE_RETRY_ATTEMPTS=4
GATE_CIRCUIT_FAILURE_THRESHOLD=5
GATE_CIRCUIT_RECOVERY_SECONDS=30

# Bitget v2 USDT-M Futures: create an API key with futures read/trade only;
# do not enable withdrawal permission. Passphrase is required by Bitget.
BITGET_REST_BASE_URL=https://api.bitget.com
BITGET_WS_URL=wss://ws.bitget.com/v2/ws/public
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_API_PASSPHRASE=
BITGET_PRODUCT_TYPE=USDT-FUTURES
BITGET_MARGIN_COIN=USDT
BITGET_MARGIN_MODE=crossed
BITGET_POSITION_MODE=one_way_mode
BITGET_REQUEST_TIMEOUT_SECONDS=15
BITGET_MAX_CONCURRENCY=8
BITGET_REQUESTS_PER_SECOND=8
BITGET_RETRY_ATTEMPTS=4
BITGET_CIRCUIT_FAILURE_THRESHOLD=5
BITGET_CIRCUIT_RECOVERY_SECONDS=30

# CoinGlass remains an analysis input only.
COINGLASS_ENABLED=false
COINGLASS_API_KEY=
COINGLASS_BASE_URL=https://open-api-v4.coinglass.com
COINGLASS_REQUEST_TIMEOUT_SECONDS=10
COINGLASS_MAX_CONCURRENCY=4
COINGLASS_REQUESTS_PER_SECOND=4
COINGLASS_RETRY_ATTEMPTS=2
COINGLASS_EXCHANGE_LIST=Binance,OKX,Bybit
COINGLASS_INTERVAL=30m
COINGLASS_HISTORY_LIMIT=48
COINGLASS_CACHE_TTL_SECONDS=1800
COINGLASS_USE_HEATMAP=true
COINGLASS_HEATMAP_RANGE=1d
COINGLASS_REQUIRE_HEATMAP=false
COINGLASS_MAX_SYMBOLS_PER_SCAN=100

# Original scanner/ranking rules; keep these unchanged when migrating venue.
MIN_24H_TURNOVER_USDT=7000000
MAX_SPREAD_PCT=0.10
MIN_30M_CANDLES=240
MIN_4H_CANDLES=150
MIN_DATA_COMPLETENESS_PCT=70
RANKING_MIN_SCORE=55
BLACKLIST_CONTRACTS=
SCAN_DELAY_SECONDS=20
SCAN_ON_STARTUP=true
SCHEDULER_ENABLED=true

# Trading and continuous position management.
AUTO_ORDER_ENABLED=true
POSITION_MANAGEMENT_ENABLED=true
POSITION_MANAGER_INTERVAL_SECONDS=5
POSITION_MARKET_REFRESH_SECONDS=15
ENTRY_ORDER_MODE=limit
LIMIT_ENTRY_OFFSET_PCT=0.0005
LIMIT_ENTRY_CANCEL_MOVE_PCT=0.005
LIMIT_ENTRY_TIMEOUT_SECONDS=180
MAX_MARKET_DRIVER_POSITIONS=2
MAX_TOTAL_POSITIONS=20
MAX_SAME_DIRECTION_ORDERS_PER_BATCH=2
MARKET_DRIVER_CONTRACTS=BTC_USDT,ETH_USDT,SOL_USDT,BNB_USDT,HYPE_USDT
MARKET_DRIVER_NOTIONAL_CONTRACTS=BTC_USDT,ETH_USDT,SOL_USDT,BNB_USDT,HYPE_USDT,ZEC_USDT
REGULAR_ALT_NOTIONAL_USDT=2000
MARKET_DRIVER_NOTIONAL_USDT=20000
BTC_ETH_NOTIONAL_USDT=40000
MINIMUM_ORDER_RR=1.0
REQUIRE_MAX_LEVERAGE=true
MAX_INITIAL_STOP_LOSS_USDT=1000
STOP_LOSS_BUFFER_ATR=0.9
FALLBACK_STOP_ATR=2.2
TAKE_PROFIT_1_PCT=0.25
TAKE_PROFIT_2_PCT=0.30
TAKE_PROFIT_3_PCT=0.25
RUNNER_PCT=0.20
ORDER_TRIGGER_EXPIRATION_SECONDS=0

# live = formal mode; test = all new-entry notionals are multiplied by 0.1.
# The dashboard mode switch persists this setting in the database.
TRADING_MODE=live
TEST_MODE_NOTIONAL_MULTIPLIER=0.1

# Use three different long random values in deployment.
TRADING_CONTROL_TOKEN=
MANUAL_SCAN_TOKEN=
ADMIN_BEARER_TOKEN=
DISCORD_WEBHOOK_URL=
SCAN_DISCORD_WEBHOOK_URL=
ORDER_DISCORD_WEBHOOK_URL=
DISCORD_COOLDOWN_SECONDS=900
DISCORD_MAX_RETRIES=4
DISCORD_MAX_TIMEPOINTS=50
PUBLIC_BASE_URL=http://localhost:8080
REPLAY_MAX_HOURS=168
REPLAY_MAX_CONCURRENT_JOBS=1
REPLAY_REQUIRE_HISTORICAL_SPREAD=true
REPLAY_REQUIRE_HISTORICAL_ACTIVE_FLOW=false
REPLAY_CACHE_TTL_SECONDS=3600
BACKTEST_DEFAULT_FEE_PCT=0.05
BACKTEST_DEFAULT_SLIPPAGE_PCT=0.02
